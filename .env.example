# ─── Server ───
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=debug
API_PREFIX=/api/v1

# ─── Database ───
DATABASE_URL=postgresql://driftaway:driftaway@localhost:5432/driftaway?schema=public

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_REFRESH_SECRET=change-me-to-another-random-256-bit-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Twilio (OTP) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── hCaptcha ───
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000
HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000000

# ─── AI Providers ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_KEY=

# ─── WhatsApp Business API ───
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── S3 / MinIO ───
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=driftaway
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─── Google Maps ───
GOOGLE_MAPS_API_KEY=

# ─── Email (Resend) ───
RESEND_API_KEY=

# ─── Frontend URL ───
FRONTEND_URL=http://localhost:3000

# ─── Exchange Rate API ───
EXCHANGE_RATE_API_KEY=
