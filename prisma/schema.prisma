generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum UserRole {
  superadmin
  user
}

enum TripStatus {
  draft
  planning
  confirmed
  active
  completed
  cancelled
}

enum TripRole {
  organizer
  participant
  viewer
}

enum TravelStyle {
  backpacker
  comfort
  luxury
  adventure
}

enum BookingType {
  flight
  hotel
  train
  bus
  activity
  ferry
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

enum ActivityType {
  hotel
  sightseeing
  dining
  transport
  adventure
  culture
  wellness
  shopping
  other
}

enum AIProvider {
  openai
  claude
  gemini
}

enum NotificationChannel {
  push
  email
  whatsapp
  sms
}

enum DocumentType {
  passport
  visa
  ticket
  insurance
  hotel_confirmation
  itinerary
  other
}

// ─── Core Models ───

model User {
  id                String    @id @default(uuid()) @db.Uuid
  phone             String    @unique @db.VarChar(20)
  name              String    @db.VarChar(100)
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  avatarUrl         String?   @map("avatar_url") @db.Text
  role              UserRole  @default(user)
  homeCity          String?   @map("home_city") @db.VarChar(100)
  homeLatitude      Float?    @map("home_latitude")
  homeLongitude     Float?    @map("home_longitude")
  passportExpiry    DateTime? @map("passport_expiry") @db.Date
  emergencyContact  Json?     @map("emergency_contact") @db.JsonB
  preferences       Json?     @db.JsonB // diet, allergies, interests, travelStyle, languages, accessibility, transportPref
  frequentFlyerIds  Json?     @map("frequent_flyer_ids") @db.JsonB
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  minors            Minor[]
  tripMemberships   TripMember[]
  createdTrips      Trip[]            @relation("TripCreator")
  documents         Document[]
  expenses          Expense[]
  refreshTokens     RefreshToken[]
  otpCodes          OtpCode[]
  auditLogs         AuditLog[]        @relation("AuditUser")

  @@map("users")
}

model Minor {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(100)
  dateOfBirth     DateTime  @map("date_of_birth") @db.Date
  guardianId      String    @map("guardian_id") @db.Uuid
  specialNeeds    String?   @map("special_needs") @db.Text
  preferences     Json?     @db.JsonB // favActivities, dietaryNeeds
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  guardian        User      @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  tripMinors      TripMinor[]

  @@map("minors")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  token       String    @unique @db.VarChar(500)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz()

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpCode {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  phone       String    @db.VarChar(20)
  code        String    @db.VarChar(6)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz()
  attempts    Int       @default(0)
  verifiedAt  DateTime? @map("verified_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
  @@map("otp_codes")
}

// ─── Trip Models ───

model Trip {
  id                String      @id @default(uuid()) @db.Uuid
  title             String      @db.VarChar(200)
  destination       String      @db.VarChar(200)
  subDestinations   String[]    @map("sub_destinations")
  startDate         DateTime    @map("start_date") @db.Date
  endDate           DateTime    @map("end_date") @db.Date
  currency          String      @default("INR") @db.VarChar(3)
  budgetTotal       Decimal?    @map("budget_total") @db.Decimal(12, 2)
  budgetSpent       Decimal     @default(0) @map("budget_spent") @db.Decimal(12, 2)
  aiProvider        AIProvider  @default(claude) @map("ai_provider")
  status            TripStatus  @default(draft)
  preferences       Json?       @db.JsonB // pace, focusAreas, avoidCrowds, etc.
  bannerConfig      Json?       @map("banner_config") @db.JsonB // gradient, emoji, imageUrl
  whatsappGroupId   String?     @map("whatsapp_group_id") @db.VarChar(100)
  createdById       String      @map("created_by_id") @db.Uuid
  isSeed            Boolean     @default(false) @map("is_seed")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt         DateTime?   @map("deleted_at") @db.Timestamptz()

  // Relations
  createdBy         User        @relation("TripCreator", fields: [createdById], references: [id])
  members           TripMember[]
  tripMinors        TripMinor[]
  itineraryDays     ItineraryDay[]
  bookings          Booking[]
  checklistItems    ChecklistItem[]
  documents         Document[]
  expenses          Expense[]
  transportNotes    TransportNote[]
  reminders         Reminder[]
  aiConversations   AIConversation[]

  @@index([createdById])
  @@index([status])
  @@map("trips")
}

model TripMember {
  id              String    @id @default(uuid()) @db.Uuid
  tripId          String    @map("trip_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  role            TripRole  @default(participant)
  startCity       String?   @map("start_city") @db.VarChar(100)
  startLatitude   Float?    @map("start_latitude")
  startLongitude  Float?    @map("start_longitude")
  joinedAt        DateTime  @default(now()) @map("joined_at") @db.Timestamptz()

  trip            Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@map("trip_members")
}

model TripMinor {
  id        String    @id @default(uuid()) @db.Uuid
  tripId    String    @map("trip_id") @db.Uuid
  minorId   String    @map("minor_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  minor     Minor     @relation(fields: [minorId], references: [id], onDelete: Cascade)

  @@unique([tripId, minorId])
  @@map("trip_minors")
}

// ─── Itinerary Models ───

model ItineraryDay {
  id          String    @id @default(uuid()) @db.Uuid
  tripId      String    @map("trip_id") @db.Uuid
  dayNumber   Int       @map("day_number")
  date        DateTime  @db.Date
  title       String    @db.VarChar(200)
  summary     String?   @db.Text             // one-line summary of the day
  accommodation String? @db.VarChar(200)     // hotel/accommodation name for this night
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items       ItineraryItem[]

  @@unique([tripId, dayNumber])
  @@map("itinerary_days")
}

model ItineraryItem {
  id              String        @id @default(uuid()) @db.Uuid
  dayId           String        @map("day_id") @db.Uuid
  sortOrder       Int           @map("sort_order")
  time            String        @db.VarChar(5) // HH:MM
  activity        String        @db.VarChar(500)
  type            ActivityType
  latitude        Float?
  longitude       Float?
  costLocal       Decimal?      @map("cost_local") @db.Decimal(12, 2)
  costConverted   Decimal?      @map("cost_converted") @db.Decimal(12, 2)
  localCurrency   String?       @map("local_currency") @db.VarChar(3)
  thumbnail       String?       @db.Text
  notes           String?       @db.Text
  tip             String?       @db.Text              // practical tip separate from notes
  highlight       Boolean       @default(false) @map("is_highlight")
  bookingRequired Boolean       @default(false) @map("booking_required")
  closedOn        String[]      @map("closed_on")     // e.g. ["Monday","Tuesday"]
  openingHours    String?       @map("opening_hours") @db.VarChar(100)
  bookingId       String?       @map("booking_id") @db.Uuid
  participants    String[]      @db.Uuid
  accessibility   String[]
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  day             ItineraryDay  @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId, sortOrder])
  @@map("itinerary_items")
}

// ─── Booking ───

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  tripId          String        @map("trip_id") @db.Uuid
  type            BookingType
  status          BookingStatus @default(pending)
  carrier         String?       @db.VarChar(100) // airline, hotel chain, etc.
  name            String?       @db.VarChar(300) // hotel name, activity name
  fromLocation    String?       @map("from_location") @db.VarChar(100)
  toLocation      String?       @map("to_location") @db.VarChar(100)
  departureDate   DateTime?     @map("departure_date") @db.Date
  departureTime   String?       @map("departure_time") @db.VarChar(5)
  arrivalDate     DateTime?     @map("arrival_date") @db.Date
  arrivalTime     String?       @map("arrival_time") @db.VarChar(5)
  checkIn         DateTime?     @map("check_in") @db.Date
  checkOut        DateTime?     @map("check_out") @db.Date
  confirmationRef String?       @map("confirmation_ref") @db.VarChar(50)
  cost            Decimal?      @db.Decimal(12, 2)
  currency        String?       @db.VarChar(3)
  travelers       String[]      @db.Uuid
  details         Json?         @db.JsonB // seat, class, room type, baggage, etc.
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  trip            Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("bookings")
}

// ─── Checklist ───

model ChecklistItem {
  id          String    @id @default(uuid()) @db.Uuid
  tripId      String    @map("trip_id") @db.Uuid
  text        String    @db.VarChar(300)
  category    String    @db.VarChar(50)
  isChecked   Boolean   @default(false) @map("is_checked")
  assignedTo  String?   @map("assigned_to") @db.Uuid // specific traveler or null = all
  isAiGenerated Boolean @default(false) @map("is_ai_generated")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, category])
  @@map("checklist_items")
}

// ─── Documents ───

model Document {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  tripId      String?       @map("trip_id") @db.Uuid
  type        DocumentType
  name        String        @db.VarChar(200)
  s3Key       String        @map("s3_key") @db.Text
  mimeType    String        @map("mime_type") @db.VarChar(100)
  sizeBytes   Int           @map("size_bytes")
  expiryDate  DateTime?     @map("expiry_date") @db.Date
  metadata    Json?         @db.JsonB
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip        Trip?         @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tripId])
  @@map("documents")
}

// ─── Budget & Expenses ───

model Expense {
  id          String    @id @default(uuid()) @db.Uuid
  tripId      String    @map("trip_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @db.VarChar(3)
  category    String    @db.VarChar(50)
  description String?   @db.VarChar(300)
  receiptUrl  String?   @map("receipt_url") @db.Text
  isShared    Boolean   @default(false) @map("is_shared")
  splitWith   String[]  @map("split_with") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([tripId])
  @@map("expenses")
}

// ─── Transport & Destination Info ───

model TransportNote {
  id        String    @id @default(uuid()) @db.Uuid
  tripId    String    @map("trip_id") @db.Uuid
  icon      String    @db.VarChar(10)
  title     String    @db.VarChar(100)
  detail    String    @db.Text
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("transport_notes")
}

// ─── Reminders ───

model Reminder {
  id          String              @id @default(uuid()) @db.Uuid
  tripId      String              @map("trip_id") @db.Uuid
  scheduledAt DateTime            @map("scheduled_at") @db.Timestamptz()
  message     String              @db.Text
  channel     NotificationChannel @default(push)
  sentAt      DateTime?           @map("sent_at") @db.Timestamptz()
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  trip        Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([scheduledAt])
  @@map("reminders")
}

// ─── AI Conversations ───

model AIConversation {
  id          String      @id @default(uuid()) @db.Uuid
  tripId      String      @map("trip_id") @db.Uuid
  provider    AIProvider
  messages    Json        @db.JsonB // array of { role, content }
  tokensUsed  Int         @default(0) @map("tokens_used")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  trip        Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("ai_conversations")
}

// ─── Admin / Brand ───

model BrandConfig {
  id            String    @id @default(uuid()) @db.Uuid
  appName       String    @default("DriftAway") @map("app_name") @db.VarChar(100)
  tagline       String    @default("plan less. live more.") @db.VarChar(200)
  logoUrl       String?   @map("logo_url") @db.Text
  primaryColor  String    @default("#FF6B35") @map("primary_color") @db.VarChar(7)
  accentColor   String    @default("#06D6A0") @map("accent_color") @db.VarChar(7)
  darkColor     String    @default("#1A1A2E") @map("dark_color") @db.VarChar(7)
  surfaceColor  String    @default("#F8F7F4") @map("surface_color") @db.VarChar(7)
  fontDisplay   String    @default("Outfit") @map("font_display") @db.VarChar(100)
  fontBody      String    @default("Space Grotesk") @map("font_body") @db.VarChar(100)
  extras        Json?     @db.JsonB // splash config, email templates, etc.
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("brand_config")
}

// ─── Audit Log ───

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  action      String    @db.VarChar(50)
  entity      String    @db.VarChar(50)
  entityId    String?   @map("entity_id") @db.Uuid
  diff        Json?     @db.JsonB
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user        User?     @relation("AuditUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
